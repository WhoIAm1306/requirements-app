# Скопируйте в файл .env в корне репозитория (рядом с docker-compose.yml).
# Docker Compose подхватит переменные автоматически.

APP_PORT=8080

DB_USER=requirements_user
DB_PASSWORD=замените-на-сложный-пароль
DB_NAME=requirements_db

JWT_SECRET=замените-на-длинную-случайную-строку

# URL, с которого пользователи открывают сайт (для CORS).
FRONTEND_ORIGIN=http://127.0.0.1:8080

SUPERUSER_FULL_NAME=Администратор
SUPERUSER_ORGANIZATION=Компания
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=замените-пароль-первого-входа
