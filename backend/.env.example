# Скопируйте в .env и задайте свои значения.
APP_PORT=8080

# Origin фронтенда для CORS (URL, по которому открывают сайт в браузере).
# Для одного сервера с бэкендом: http://YOUR_SERVER_IP:8080 или https://your-domain.ru
FRONTEND_ORIGIN=http://localhost:8080

JWT_SECRET=замените-на-длинную-случайную-строку

DB_HOST=localhost
DB_PORT=5432
DB_NAME=requirements_db
DB_USER=requirements_user
DB_PASSWORD=замените-пароль
DB_SSLMODE=disable

SUPERUSER_FULL_NAME=Администратор
SUPERUSER_ORGANIZATION=Компания
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=замените-пароль-админа
